# Environment Variables Template
# Copy this file to .env and fill in the actual values

# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=finalproject
DB_PORT=5432

# Application Configuration
PORT=8080
GIN_MODE=release

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here_at_least_32_characters

# Docker Configuration
DOCKER_REGISTRY=ghcr.io
IMAGE_TAG=latest

# Coolify Configuration (for deployment)
COOLIFY_URL=https://your-coolify-instance.com
COOLIFY_API_TOKEN=your_coolify_api_token_here

# Jenkins Configuration
JENKINS_URL=https://jenkins.egodev.tech
JENKINS_API_TOKEN=your_jenkins_api_token_here

# Monitoring & Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# External Services (if needed)
REDIS_URL=redis://localhost:6379
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password